# --- Runtime Configuration ---
# The model runtime to use ('mlx', 'ollama', etc.)
RUNTIME="ollama"

# --- Agent Architecture ---
AGENT_ARCH="world_model"

# --- VLM Model Configuration (for Perception) ---
# Model identifier for the multimodal Vision-Language Model
PERCEPTION_MODEL_ID="mlx-community/Qwen3-VL-4B-Instruct-3bit"

# --- LLM Model Configuration (for Simulator & Controller) ---
# Note: These models might require Hugging Face authentication to download.
CONTROLLER_MODEL_ID="mlx-community/Qwen3-1.7B-4bit"

# --- Ollama Configuration ---
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_REQUEST_TIMEOUT=600
OLLAMA_CONTEXT_SIZE=20480
OLLAMA_PERCEPTION_MODEL="llava:latest"
OLLAMA_CONTROLLER_MODEL="qwen3:0.6b"

# --- Environment Configuration ---
GYM_ENVIRONMENT="MiniGrid-Empty-8x8-v0"
# Render mode: "human" for live view, "rgb_array" for internal rendering mode producing frames, "record" for video recording
# RENDER_MODE="human"
RENDER_MODE="record"

# --- Agent Run Configuration ---
# Max steps per episode
MAX_STEPS=25
# High-level instruction for the agent
INSTRUCTION="Navigate to the green square and stop."
# Number of past steps to remember for memory
MEMORY_LENGTH=4

# --- Recording Configuration ---
# Directory to save agent run recordings
RECORDING_DIR="outputs/recordings"
